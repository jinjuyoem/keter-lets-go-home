# NAVER Datalab (Trend) API Keys
# Get these from: https://developers.naver.com/apps/#/register
VITE_NAVER_CLIENT_ID=your_client_id_here
VITE_NAVER_CLIENT_SECRET=your_client_secret_here

# NAVER Search AD API Keys (Optional, fallback keys provided in code)
# Get these from: https://searchad.naver.com/ (Manage API)
VITE_NAVER_SEARCHAD_LICENSE=your_license_key_here
VITE_NAVER_SEARCHAD_CUSTOMER_ID=your_customer_id_here
VITE_NAVER_SEARCHAD_SECRET=your_secret_key_here
